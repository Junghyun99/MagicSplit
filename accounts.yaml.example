# 멀티 계좌 설정 템플릿
#
# 1. 이 파일을 `accounts.yaml`로 복사합니다.
# 2. 각 계좌의 id / market_type / is_live / engine / kis_env_prefix를 지정합니다.
# 3. 시크릿은 .env 파일에 `{PREFIX}_KIS_APP_KEY`, `{PREFIX}_KIS_APP_SECRET`,
#    `{PREFIX}_KIS_ACC_NO` 형식으로 저장합니다 (prefix는 아래 kis_env_prefix와 동일).
#
# engine 값은 src/core/engine 디렉토리에 @register_engine 으로 등록된 이름을 사용합니다.
# 예: MagicSplitEngine

accounts:
  - id: my_account
    market_type: overseas      # overseas | domestic
    is_live: false             # true: 실전, false: 모의
    engine: MagicSplitEngine
    kis_env_prefix: MY_ACCOUNT
